# ============================================================
# Language Tutor — Environment Variables
# Copy this file to .env in apps/api/ and fill in the values
# ============================================================

# Google Gemini API Key (free tier: https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (default: 3001)
PORT=3001

# CORS origin for the Next.js frontend (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000
